def _splay_socket_path():
    # Prefer $XDG_RUNTIME_DIR (/run/user/$UID) — per-user, not subject to
    # systemd-tmpfiles cleaning of /tmp, which previously could remove the
    # bound socket file mid-session and break IPC handoff.
    runtime = os.environ.get("XDG_RUNTIME_DIR")
    if runtime and os.path.isdir(runtime):
        return os.path.join(runtime, "splay.sock")
    return f"/tmp/splay-{os.environ.get('USER', 'user')}.sock"


SPLAY_SOCKET_PATH = _splay_socket_path()


def send_to_running_instance(abs_paths):
    """Try to deliver a list of absolute paths to a running splay.
    Returns True if delivered, False if no instance is listening."""
    if not os.path.exists(SPLAY_SOCKET_PATH):
        print(f"splay: no running instance (socket {SPLAY_SOCKET_PATH} absent)",
              file=sys.stderr)
        return False
    try:
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        s.settimeout(0.5)
        s.connect(SPLAY_SOCKET_PATH)
        msg = json.dumps({"cmd": "open", "paths": abs_paths}) + "\n"
        s.sendall(msg.encode())
        s.close()
        return True
    except (OSError, socket.timeout) as e:
        print(f"splay: IPC handoff failed ({e}); unlinking stale socket "
              f"{SPLAY_SOCKET_PATH}", file=sys.stderr)
        try: os.unlink(SPLAY_SOCKET_PATH)  # stale
        except OSError: pass
        return False

