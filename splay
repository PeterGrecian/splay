def gather_paths(args):
    if not args:
        args = ["."]
    out = []
    dirs = []
    for a in args:
        p = pathlib.Path(a)
        if p.is_dir():
            dirs.append(p)
            out.extend(sorted(x for x in p.iterdir()
                              if x.suffix.lower() in IMG_EXTS))
        elif p.is_file():
            if p.suffix.lower() in IMG_EXTS:
                out.append(p)
            else:
                print(f"skip: {p} unsupported extension", file=sys.stderr)
        else:
            print(f"skip: {p} not found", file=sys.stderr)
    return out, dirs


def fit_into(img_w, img_h, box_w, box_h):
    if img_w == 0 or img_h == 0:
        return box_w, box_h
    s = min(box_w / img_w, box_h / img_h)
    return max(1, int(img_w * s)), max(1, int(img_h * s))


# ---- app loader --------------------------------------------------------------

APP_DIRS = [
    pathlib.Path(__file__).resolve().parent / "apps",            # in-repo
    pathlib.Path.home() / ".config" / "splay" / "apps",          # user
]


def load_app(name):
    """Load app module by name. In-repo wins over user dir."""
    for d in APP_DIRS:
        f = d / f"{name}.py"
        if f.is_file():
            spec = importlib.util.spec_from_file_location(f"splay_app_{name}", f)
            mod = importlib.util.module_from_spec(spec)
            spec.loader.exec_module(mod)
            # Initialise defaults from PARAMS.
            mod._defaults = {k: v[2] for k, v in getattr(mod, "PARAMS", {}).items()}
            return mod
    raise SystemExit(f"app not found: {name}  (searched: {[str(d) for d in APP_DIRS]})")


def list_apps():
    seen = set()
    for d in APP_DIRS:
        if not d.is_dir(): continue
        for f in sorted(d.glob("*.py")):
            if f.stem.startswith("_"): continue
            if f.stem in seen: continue
            seen.add(f.stem)
            print(f"  {f.stem:20s} {f}")


